From 76e5198fccf07958ce8f84bb5eb24a03554411e3 Mon Sep 17 00:00:00 2001
From: Pete Moore <pmoore@mozilla.com>
Date: Sat, 9 May 2026 21:42:22 +0200
Subject: [PATCH] Add -exitonhalt option for batch / CI usage

Adds a new boolean option, exitonhalt (off by default), that causes
SimCoupe to quit cleanly when the running Z80 program executes HALT
with interrupts disabled (DI + HALT).

This is the conventional 'we are done' signal used by automated test
harnesses on the Z80 family of machines: the emulator can never make
progress past a DI + HALT (no interrupt will ever fire to wake the
CPU), so treating it as a clean exit is unambiguous and avoids the
need for external timeout / process kill heuristics in CI.

The option is only ever read from the command line (e.g.
'simcoupe -exitonhalt 1 disk.mgt') and is deliberately not persisted
to SimCoupe.cfg, since it's a per-invocation harness flag rather than
a user preference.

The Z80 core's existing on_halt hook (kosarev/z80) is overridden in
sam_cpu; if the option is set and IFF1 is clear, the main emulation
loop is asked to quit. Without the option set, behaviour is unchanged:
the Z80 enters its normal HALT state and waits for the next interrupt.
---
 Base/CPU.cpp     |  3 ++-
 Base/CPU.h       | 16 ++++++++++++++++
 Base/Options.cpp |  3 +++
 Base/Options.h   |  2 ++
 4 files changed, 23 insertions(+), 1 deletion(-)

diff --git a/Base/CPU.cpp b/Base/CPU.cpp
index cd89f17..d1dbc67 100644
--- a/Base/CPU.cpp
+++ b/Base/CPU.cpp
@@ -54,6 +54,7 @@ sam_cpu cpu;
 
 
 bool g_fBreak, g_fPaused;
+bool g_fQuit;
 int g_nTurbo;
 
 constexpr auto max_boot_frames{ 200 };
@@ -150,7 +151,7 @@ void ExecuteChunk()
 
 void Run()
 {
-    while (UI::CheckEvents())
+    while (!g_fQuit && UI::CheckEvents())
     {
         if (g_fPaused)
             continue;
diff --git a/Base/CPU.h b/Base/CPU.h
index 669c92b..8b80887 100644
--- a/Base/CPU.h
+++ b/Base/CPU.h
@@ -65,6 +65,7 @@ extern uint8_t last_in_val, last_out_val;
 }
 
 extern bool g_fBreak, g_fPaused;
+extern bool g_fQuit;
 extern int g_nTurbo;
 
 #ifdef _DEBUG
@@ -158,6 +159,21 @@ struct sam_cpu : public z80::z80_cpu<sam_cpu>
         base::on_rst(nn);
     }
 
+    void on_halt()
+    {
+        // Batch-mode: quit cleanly when the program executes HALT with interrupts
+        // disabled. This is the standard "we're done, kill the emulator" signal
+        // used by automated test harnesses (e.g. CI round-trip suites). Without
+        // -exitonhalt, behaviour is unchanged: the Z80 enters its normal HALT
+        // state and waits for the next interrupt.
+        if (GetOption(exitonhalt) && !base::on_get_iff1())
+        {
+            g_fQuit = true;
+            g_fBreak = true;
+        }
+        base::on_halt();
+    }
+
     z80::fast_u8 on_get_int_vector()
     {
         if (!GetOption(im2random))
diff --git a/Base/Options.cpp b/Base/Options.cpp
index 53ad5d3..f308846 100644
--- a/Base/Options.cpp
+++ b/Base/Options.cpp
@@ -142,6 +142,7 @@ static bool SetNamedValue(const std::string& option_name, const std::string& str
     else if (name == "breakonexec") SetValue(g_config.breakonexec, str);
     else if (name == "fkeys") SetValue(g_config.fkeys, str);
     else if (name == "rasterdebug") SetValue(g_config.rasterdebug, str);
+    else if (name == "exitonhalt") SetValue(g_config.exitonhalt, str);
     else
     {
         return false;
@@ -318,6 +319,8 @@ bool Save()
         ofs << "breakonexec=" << to_string(g_config.breakonexec) << std::endl;
         ofs << "fkeys=" << to_string(g_config.fkeys) << std::endl;
         ofs << "rasterdebug=" << to_string(g_config.rasterdebug) << std::endl;
+        // exitonhalt is intentionally not persisted: it's a transient batch-mode flag
+        // that should only be set per-invocation via the command line.
     }
     catch (...)
     {
diff --git a/Base/Options.h b/Base/Options.h
index b392eee..a7c9935 100644
--- a/Base/Options.h
+++ b/Base/Options.h
@@ -127,6 +127,8 @@ struct Config
     bool breakonexec = false;           // Break on code auto-execute?
     bool rasterdebug = true;            // Raster-accurate debugger display
 
+    bool exitonhalt = false;            // Quit cleanly when Z80 executes HALT with interrupts disabled (batch mode)
+
     std::string fkeys =                 // Function key bindings
         "F1=InsertDisk1,SF1=EjectDisk1,AF1=NewDisk1,CF1=SaveDisk1,"
         "F2=InsertDisk2,SF2=EjectDisk2,AF2=NewDisk2,CF2=SaveDisk2,"
