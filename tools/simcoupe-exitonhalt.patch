From 2ea4c7ce4da6de417b7fa7ee1ce904003a617c00 Mon Sep 17 00:00:00 2001
From: Pete Moore <pmoore@mozilla.com>
Date: Sat, 9 May 2026 14:32:13 +0200
Subject: [PATCH 2/2] Quit on Z80 DI;HALT when exitonhalt=1
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Add a clean-exit mechanism for batch/CI use: when the Z80 executes
HALT with interrupts disabled and `-exitonhalt 1` was passed on the
command line, SimCoupé sets a quit flag and the main Run() loop
exits cleanly with exit code 0.

A HALT with IFF1=0 can never be woken by a maskable interrupt, so it
is an unambiguous "we are done" signal from the Z80 program — the
conventional Z80 idiom. Without `-exitonhalt`, behaviour is
unchanged: the Z80 enters its normal HALT state and waits for the
next interrupt, exactly as before.

Mechanism: `sam_cpu::on_halt` is overridden to check the option and
the IFF1 flag, set a new file-scope `g_fQuit` if both conditions
match, then call `base::on_halt()` so the underlying Z80 HALT
bookkeeping is unchanged. The main `Run()` loop guard is extended
to `while (!g_fQuit && UI::CheckEvents())` so the loop exits on
the next iteration after the magic HALT.
---
 Base/CPU.cpp |  3 ++-
 Base/CPU.h   | 17 +++++++++++++++++
 2 files changed, 19 insertions(+), 1 deletion(-)

diff --git a/Base/CPU.cpp b/Base/CPU.cpp
index cd89f17..d1dbc67 100644
--- a/Base/CPU.cpp
+++ b/Base/CPU.cpp
@@ -54,6 +54,7 @@ sam_cpu cpu;
 
 
 bool g_fBreak, g_fPaused;
+bool g_fQuit;
 int g_nTurbo;
 
 constexpr auto max_boot_frames{ 200 };
@@ -150,7 +151,7 @@ void ExecuteChunk()
 
 void Run()
 {
-    while (UI::CheckEvents())
+    while (!g_fQuit && UI::CheckEvents())
     {
         if (g_fPaused)
             continue;
diff --git a/Base/CPU.h b/Base/CPU.h
index 669c92b..1379425 100644
--- a/Base/CPU.h
+++ b/Base/CPU.h
@@ -65,6 +65,7 @@ extern uint8_t last_in_val, last_out_val;
 }
 
 extern bool g_fBreak, g_fPaused;
+extern bool g_fQuit;
 extern int g_nTurbo;
 
 #ifdef _DEBUG
@@ -158,6 +159,22 @@ struct sam_cpu : public z80::z80_cpu<sam_cpu>
         base::on_rst(nn);
     }
 
+    void on_halt()
+    {
+        // Batch-mode: quit cleanly when the Z80 executes HALT with
+        // interrupts disabled. A HALT with IFF1=0 can never be woken
+        // by a maskable interrupt, so it is an unambiguous "we are done"
+        // signal from the Z80 program. Without -exitonhalt, behaviour is
+        // unchanged: the Z80 enters its normal HALT state and waits for
+        // the next interrupt.
+        if (GetOption(exitonhalt) && !base::on_get_iff1())
+        {
+            g_fQuit = true;
+            g_fBreak = true;
+        }
+        base::on_halt();
+    }
+
     z80::fast_u8 on_get_int_vector()
     {
         if (!GetOption(im2random))
-- 
